{
  "description": "Pre-load skill guidance when Honeydew MCP query tools are called",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*__(get_data_from_fields|get_sql_from_fields|ask_question_get_data|ask_question_get_sql|ask_deep_analysis_question)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/guide-query.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
